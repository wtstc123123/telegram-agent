# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=telegram-ai-agent-starter
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
BASE_URL=https://example.com

# ── AWS Secrets Manager (optional) ─────────────────────────────────────────────
# Set LOAD_SECRETS_MANAGER=true to fetch secrets from AWS Secrets Manager at
# startup. Existing environment variables are NOT overwritten.
LOAD_SECRETS_MANAGER=false
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_SECRET_ID=

# ── Telegram ────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── OpenAI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low

# ── Redis (session store) ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=86400

# ── Primary Data API ─────────────────────────────────────────────────────────────
PRIMARY_DATA_API_BASE_URL=
PRIMARY_DATA_API_KEY=
PRIMARY_DATA_API_TIMEOUT_SECONDS=20
PRIMARY_DATA_API_NAME=primary_data_api

# ── Billing API ──────────────────────────────────────────────────────────────────
BILLING_API_BASE_URL=
BILLING_API_KEY=
BILLING_API_TIMEOUT_SECONDS=20
BILLING_API_NAME=billing_api
